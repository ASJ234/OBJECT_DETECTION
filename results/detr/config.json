{
  "model": {
    "name": "DETR-ResNet50",
    "num_classes": 3
  },
  "training": {
    "epochs": 150,
    "batch_size": 8,
    "lr_backbone": 1e-05,
    "lr_transformer": 0.0001,
    "lr_head": 0.0001,
    "weight_decay": 0.0001,
    "clip_norm": 0.1,
    "warmup_epochs": 10,
    "ema_decay": 0.99,
    "early_stop_patience": 30,
    "save_every": 10,
    "seed": 42,
    "resume": null,
    "gradient_accumulation_steps": 4
  },
  "augmentation": {
    "hflip_prob": 0.5,
    "brightness": 0.3,
    "contrast": 0.3,
    "gamma": 0.2,
    "noise_std": 0.05,
    "normalize": true
  },
  "data": {
    "train_images": "dataset/coco/train",
    "val_images": "dataset/coco/val",
    "train_ann": "dataset/coco/train.json",
    "val_ann": "dataset/coco/val.json",
    "test_images": "dataset/coco/test",
    "test_ann": "dataset/coco/test.json",
    "num_workers": 2
  },
  "results_dir": "results/detr"
}